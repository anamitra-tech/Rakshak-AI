# Copy this file to .env (same directory, repo root) and fill in real
# values. Never commit the real .env -- it's gitignored on purpose.
#
# llm/client.py loads this file relative to its own path (two directories
# up), so it must live at the repo root -- NOT inside prahari_dashboard_backend/
# or any other subproject. That's true regardless of which service actually
# calls into llm.client (ml/llm_explainer.py, rag/retriever.py, bot/agent.py,
# and by extension prahari_dashboard_backend's /api/analyze online mode and
# /api/chat both go through this).

# --- LLM fallback chain (llm/client.py) ---
# Tried in this order by default: Groq -> Gemini -> Nemotron -> Ollama.
# Only Groq and Gemini are required for the chain to be useful; Nemotron is
# an optional third tier, and Ollama (local, no key needed) is the last-
# resort fallback if it's running locally with the right model pulled.
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# --- Used by other AI/ML modules in this repo, not required for
#     prahari_dashboard_backend's currently-wired routes ---
SARVAM_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
PUBLIC_BASE_URL=
CHAT_API_KEY=
