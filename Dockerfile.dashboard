# prahari_dashboard_backend (FastAPI, /api/*) + prahari_dashboard_frontend
# (React/Vite command-center dashboard), served as ONE Render web service so
# the frontend's hardcoded relative fetch('/api/...') calls resolve same-
# origin -- no CORS/cross-site-cookie handling needed. /api/chat is commented
# out in app/main.py (same bge-m3/faiss/torch RAM problem as webhook.app's
# /chat -- won't fit Render free tier's 512MB); everything else (analyze,
# trends, entities, network, geospatial, report, auth, health) is live.

# --- Stage 1: build the React frontend -----------------------------------
FROM node:22-slim AS frontend-build
WORKDIR /frontend
COPY prahari_dashboard_frontend/package.json prahari_dashboard_frontend/package-lock.json ./
RUN npm ci
COPY prahari_dashboard_frontend/ ./
RUN npm run build

# --- Stage 2: Python runtime ----------------------------------------------
FROM python:3.11-slim
WORKDIR /app

COPY prahari_dashboard_backend/requirements-render.txt .
RUN pip install --no-cache-dir -r requirements-render.txt

# Repo root -- prahari_dashboard_backend/app/main.py's own sys.path.insert
# reaches up into ml/, graph/, dashboard/, llm/ from here.
COPY . .
COPY --from=frontend-build /frontend/dist ./prahari_dashboard_frontend/dist

WORKDIR /app/prahari_dashboard_backend
ENV PYTHONUNBUFFERED=1

CMD python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}
