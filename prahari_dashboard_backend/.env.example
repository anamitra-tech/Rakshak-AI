# Copy this file to .env and fill in real values.
# The app runs fine with all of these blank.

# STALE as of 2026-07-22: this comment used to point at
# classifier_placeholder.py, which no longer exists -- the real classifier
# (ml/detector.py + ml/llm_explainer.py) has been wired in since. These two
# fields are still not read by anything in this app though (app/core/
# config.py's Settings.gemini_api_key/groq_api_key are unused dead fields --
# nothing in app/ ever reads settings.gemini_api_key). The keys that
# actually matter for /api/analyze (online mode) and /api/chat are read
# directly by llm/client.py from a *separate* .env at the REPO ROOT (see
# ../.env.example), not from this file. Left here, correctly blank, in case
# a future feature actually wires these Settings fields to something --
# don't assume that's happened just because they're present.
GEMINI_API_KEY=
GROQ_API_KEY=

MAPBOX_TOKEN=

FRONTEND_ORIGIN=http://localhost:5173

# --- Auth ---
GOOGLE_CLIENT_ID=
SESSION_SECRET=dev-insecure-secret-change-me
