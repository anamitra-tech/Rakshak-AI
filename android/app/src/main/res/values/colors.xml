<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Risk-level colors — the traffic-light safety signal (WarningActivity,
         AutoEscalationCountdownActivity). Deliberately NOT touched by the
         app-wide brand theme below: a HIGH-risk scam warning must stay
         visually distinct from a normal screen, so these are set at runtime
         per risk level instead of inheriting the default screen background.
         Per "SOC Nightwatch" spec: safe (risk_low) and warning (risk_medium)
         are explicitly unchanged ("keep as-is" / "stays amber"); risk_high
         is the one deliberate value change, #C62828 -> #E63946. -->
    <color name="risk_high">#E63946</color>
    <color name="risk_medium">#E65100</color>
    <color name="risk_low">#2E7D32</color>
    <color name="brand_primary">#0D1B2A</color>

    <!-- "SOC Nightwatch" app-wide brand theme (non-risk screens: home, Check
         Call, Family Setup, FSI Setup, Safe Result, loading screen).
         Contrast verified (WCAG relative-luminance formula, not eyeballed):
           text_on_background (#F1FAEE) vs screen_background: 16.27:1 — clears
             AAA (7:1) with a very wide margin.
           accent_cyan (#00B4D8) vs screen_background: 7.06:1 — also clears
             AAA, safe for secondary/hint text and highlights.
           button_text (#000000) vs button_background (#FFD60A): 14.88:1 —
             clears AAA with a wide margin. -->
    <color name="screen_background">#0D1B2A</color>
    <color name="text_on_background">#F1FAEE</color>
    <color name="accent_cyan">#00B4D8</color>
    <color name="button_background">#FFD60A</color>
    <color name="button_text">#000000</color>

    <!-- risk_high's new value (#E63946) only clears 4.17:1 against white/
         text_on_background — passes AA's large-text threshold (3:1, e.g.
         WarningActivity's 26sp bold headline) but falls short of AA's normal-
         text threshold (4.5:1). The pre-existing risk_medium amber (#E65100,
         untouched by this change) has the same shortfall against white,
         3.79:1 — this was already true before this palette change, just
         never measured. Rather than accept a contrast regression on the
         single most safety-critical screen in the app, WarningActivity's
         regular-weight body text (phoneNumberText/whyToggle/reasonsList/
         statusText/draftText) was bumped to bold + a size increase so it
         genuinely qualifies as WCAG "large text" (which only needs 3:1)
         instead of silently accepting a borderline color — see
         activity_warning.xml. -->
    <color name="debug_warning_on_background">#FFE0B2</color>
    <!-- Dividers: the pre-existing #33000000 (20%-alpha black) is nearly
         invisible against a dark background; this is the same divider
         concept at 20%-alpha white instead. -->
    <color name="divider_on_background">#33FFFFFF</color>
</resources>
