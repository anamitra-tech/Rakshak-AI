<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#B00020">

    <!--
      Shown immediately in onCreate, before TTS or the countdown — text must
      never wait on audio. Stays visible for the rest of this screen's
      lifetime, including once the countdown below starts.
    -->
    <TextView
        android:id="@+id/riskLevelText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        tools:text="🚨 HIGH RISK" />

    <TextView
        android:id="@+id/reasonText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        tools:text="This looks like a scam. Do not share any code or send money." />

    <TextView
        android:id="@+id/countdownHeadline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        tools:text="Calling for help in 10 seconds" />

    <FrameLayout
        android:id="@+id/countdownCircleFrame"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="32dp"
        android:visibility="gone"
        tools:visibility="visible">

        <com.rakshak.ai.ui.ShrinkingCircleView
            android:id="@+id/shrinkingCircleView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/secondsRemainingText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="64sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            tools:text="10" />
    </FrameLayout>

    <Space
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/cancelButton"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:textSize="24sp"
        android:text="@string/tier3b_cancel_button" />

</LinearLayout>
