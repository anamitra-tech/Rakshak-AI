<?xml version="1.0" encoding="utf-8"?>
<!--
  Full-screen loading state for CheckCallActivity — pulsing wordmark,
  rotating reassurance phrase, and one honest stat line. Driven by
  LoadingOverlay.kt (show()/hide()), included via <include> in
  activity_check_call.xml so this stays a self-contained, reusable unit
  rather than inline elements mixed into the form layout.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:visibility="gone"
    android:clickable="true"
    android:focusable="true"
    tools:visibility="visible">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <TextView
            android:id="@+id/loadingWordmark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_on_background"
            android:textSize="40sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/loadingPhrase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:textColor="@color/text_on_background_cream"
            android:textSize="18sp"
            tools:text="Surakshit, don't take tension" />

        <TextView
            android:id="@+id/loadingStat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:alpha="0.85"
            android:gravity="center"
            android:text="@string/loading_stat_line"
            android:textColor="@color/text_on_background"
            android:textSize="13sp" />

    </LinearLayout>
</FrameLayout>
