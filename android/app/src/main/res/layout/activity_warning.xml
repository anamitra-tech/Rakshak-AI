<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp">

    <!--
      Everything informational (headline, reasons, complaint draft) scrolls
      in its own region. The action button(s) below are deliberately OUTSIDE
      this ScrollView so they stay pinned and reachable no matter how long
      the draft text gets — CLAUDE.md 9.2's "exactly one large action button"
      rule only holds if that button can't be scrolled out of view.
    -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/trafficLightEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="96sp"
                tools:text="🚨" />

            <TextView
                android:id="@+id/headlineText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                tools:text="This looks like a scam. Do not share any code or send money." />

            <!--
              textSize bumped 16sp->18sp (14sp->16sp for draftText) and all
              made bold below, on every regular-weight TextView on this
              screen: the new risk_high (#E63946) only measures 4.17:1
              against white body text — clears WCAG AA's large-text
              threshold (3:1) but not the normal-text one (4.5:1). The
              pre-existing risk_medium amber has the same shortfall
              (3.79:1), never caught before. Bold + this size increase is
              enough to genuinely qualify as WCAG "large text" instead of
              silently shipping a borderline color on the single most
              safety-critical screen in the app — see colors.xml.
            -->
            <TextView
                android:id="@+id/phoneNumberText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="From +91 98765 00001" />

            <!-- Read-only disclosure, not a competing action — see WarningActivity doc. -->
            <TextView
                android:id="@+id/whyToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:padding="8dp"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="@string/why_toggle_show" />

            <TextView
                android:id="@+id/reasonsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!--
              Complaint-draft disclosure — only surfaced in the HELP state
              (after the one primary action in the WARNING state has already
              been taken), same "read-only, non-competing" reasoning as
              whyToggle/reasonsList above.
            -->
            <TextView
                android:id="@+id/draftToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:padding="8dp"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:text="@string/complaint_draft_toggle_show" />

            <TextView
                android:id="@+id/draftText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/copyDraftButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                android:text="@string/complaint_draft_copy_button" />

            <!-- Secondary action alongside copyDraftButton above, not a
                 second competing primary action — same "read-only
                 disclosure, not a competing action" reasoning as the
                 draft toggle/copy button (see WarningActivity doc). Only
                 shown in the HELP state, same as the draft controls. -->
            <Button
                android:id="@+id/fileComplaintButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                android:text="@string/ncrp_complaint_button" />

        </LinearLayout>
    </ScrollView>

    <!-- Exactly one of these two buttons is visible at any time. Fixed
         outside the ScrollView above so it's always reachable. -->
    <Button
        android:id="@+id/primaryActionButton"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:textSize="24sp"
        android:text="@string/panic_button_label" />

    <Button
        android:id="@+id/helpActionButton"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:textSize="24sp"
        android:visibility="gone"
        android:text="@string/call_helpline_button_label" />

</LinearLayout>
