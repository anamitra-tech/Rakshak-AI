<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Backend calls to Prahari (api/server.py) — Section 7 of CLAUDE.md -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Warning card while a real call is ringing — Section 7 of CLAUDE.md -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Tier 2 real SMS to the trusted contact, carrying the complaint draft. -->
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!--
      Tier 3b only — genuine hands-off auto-dial for an illiterate/panicked
      user who may not act on a tap-to-call prompt. Requires explicit opt-in
      in family setup (AppSettings.tier3bEnabled, off by default); the
      existing Tier 3 helpline button still uses ACTION_DIAL (no permission
      needed) since that one is a deliberate user tap, not autonomous.
      Still no READ_CALL_LOG or ANSWER_PHONE_CALLS.
    -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!--
      Missed-escalation evidence agent only: observes call state after a
      Tier 3b auto-dial to estimate (by call duration, not certain — true
      answer/no-answer needs InCallService/default-dialer status, which is
      Phase 3/4) whether the call likely went unanswered. Not used for
      anything else; no call content or number history is read. Required
      alongside CALL_PHONE for Tier 3b to be enabled at all (FamilySetupActivity)
      — without it there'd be no way to ever detect an unanswered auto-dialed
      call, so it isn't left as an optional, silently-degrading extra.
    -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <application
        android:name=".RakshakApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.RakshakAI"
        android:supportsRtl="true">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.CheckCallActivity"
            android:exported="false"
            android:label="@string/check_call_title" />

        <activity
            android:name=".ui.FullScreenIntentSetupActivity"
            android:exported="false"
            android:label="@string/fsi_setup_title" />

        <activity
            android:name=".ui.FamilySetupActivity"
            android:exported="false"
            android:label="@string/family_setup_title" />

        <!--
          Tier 3b countdown — same visibility rules as WarningActivity (only
          ever started when the near-deterministic gate fires and the family
          has opted in), plus its own singleTask/lock-screen flags since it
          can supersede an already-showing WarningActivity.
        -->
        <activity
            android:name=".ui.AutoEscalationCountdownActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.RakshakAI.Warning" />

        <!--
          Shown full-screen over the lock screen the moment a risk is detected.
          Silent otherwise: this activity is never started except by the
          screening service or the Check-a-call flow when risk >= MEDIUM
          (Section 9.2 — "silent and invisible during normal calls").
        -->
        <activity
            android:name=".ui.WarningActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.RakshakAI.Warning" />

        <service
            android:name=".callscreening.RakshakCallScreeningService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

        <!--
          Missed-escalation evidence agent: records the Tier 2 SMS delivery
          report so Tier2AckTimeoutWorker can tell a genuine miss apart from
          a confirmed delivery. Not exported — only this app's own
          PendingIntent (explicit package) triggers it.
        -->
        <receiver
            android:name=".escalation.SmsDeliveryReceiver"
            android:exported="false" />

    </application>

</manifest>
