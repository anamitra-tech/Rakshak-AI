<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only: permits plain HTTP to the emulator's host-loopback alias and to
  device-local loopback (physical device reached via `adb reverse`, per
  CLAUDE.md Section 5 — chosen over a LAN IP so this doesn't depend on the
  dev machine's Windows Firewall allowing inbound LAN connections to the
  Python dev servers) so the app can reach a locally-run Prahari backend. Not
  part of the release build — debug source set only, default secure config
  applies everywhere else.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
